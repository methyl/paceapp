# Base URL of the PaceApp API. In local dev leave unset to use the vite proxy
# at /api. In production, set to the deployed Worker origin, e.g.
# VITE_API_BASE=https://paceapp-api.yourname.workers.dev/api
# VITE_API_BASE=

# Local dev only: where vite should proxy /api. Defaults to http://127.0.0.1:8787
# which is `wrangler dev` in workers/.
# VITE_API_TARGET=http://127.0.0.1:8787
